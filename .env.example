# --- Sanity ---
# Copy this file to `.env.local` and fill in the values from your Sanity project
# (https://www.sanity.io/manage). Also add these to Vercel:
# Project Settings → Environment Variables (Production, Preview, Development).

# Public — safe to expose to the browser (used by Studio + the site).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Secret — server-only. A "Viewer" read token from
# sanity.io/manage → API → Tokens. Used for Draft Mode / live preview.
# NEVER commit the real value.
SANITY_API_READ_TOKEN=

# Secret — used ONLY by the one-time `npm run seed` script to write content.
# An "Editor" token from sanity.io/manage → API → Tokens. Not needed at runtime.
SANITY_API_WRITE_TOKEN=

# --- Existing (email) ---
# RESEND_API_KEY=
